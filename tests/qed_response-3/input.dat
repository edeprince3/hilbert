# PYTHONPATH must include directory above plugin directory.
#     Define either externally or here, then import plugin.
sys.path.insert(0, '../../..')
import hilbert
import numpy as np

molecule {
0 1
O    0.00000   0.00000   0.12716
H    0.75808   0.00000  -0.50864
H   -0.75808   0.00000  -0.50864
no_reorient
nocom
symmetry c1
}

set {
  basis aug-cc-pvdz
  scf_type df
  e_convergence 1e-11
  d_convergence 1e-11
  cholesky_tolerance 1e-14
  ints_tolerance 0.0
  df_fitting_condition 1e-16
  property "POLARIZABILITY"
  omega [0.1]
} 

# freq: w
w = 0.07349864501573

# lambda: 0.05
# coupling g = 0.05 / sqrt(2*w)
g = 0.05 / np.sqrt(2.0 * w)

set hilbert {
  maxiter 500
  cavity_frequency         $w
  cavity_coupling_strength [0.0, 0.0, $g]
  maxdim                   15
  indim                    5
  qed_dft_functional pbe
}

set reference uks 
energy('qed-dft')

print('')
print('    ==> POLARIZABILITY <==')
print('')
compare_values(11.080366589638, psi4.variable("QED-DFT ALPHA(XX)"), 8, "ALPHA(XX)")
compare_values(-0.000000000000, psi4.variable("QED-DFT ALPHA(XY)"), 8, "ALPHA(XY)")
compare_values(-0.000000000001, psi4.variable("QED-DFT ALPHA(XZ)"), 8, "ALPHA(XZ)")
compare_values(10.325727080568, psi4.variable("QED-DFT ALPHA(YY)"), 8, "ALPHA(YY)")
compare_values( 0.000000000000, psi4.variable("QED-DFT ALPHA(YZ)"), 8, "ALPHA(YZ)")
compare_values( 9.861080185801, psi4.variable("QED-DFT ALPHA(ZZ)"), 8, "ALPHA(ZZ)")
