# PYTHONPATH must include directory above plugin directory.
#     Define either externally or here, then import plugin.
sys.path.insert(0, '../../..')
import hilbert 

molecule mol1 {
0 1
         O            0.000000000000     0.000000000000    -0.068516219320
         H            0.000000000000    -0.790689573744     0.543701060715
         H            0.000000000000     0.790689573744     0.543701060715
no_reorient
nocom
symmetry c1
}
molecule mol2 {
         O             0.000000000000    -0.068516219320    0.000000000000
         H            -0.790689573744     0.543701060715    0.000000000000
         H             0.790689573744     0.543701060715    0.000000000000
no_reorient
nocom
symmetry c1
}
molecule mol3 {
         O         -0.068516219320      0.000000000000     0.000000000000
         H          0.543701060715      0.000000000000    -0.790689573744
         H          0.543701060715      0.000000000000     0.790689573744
no_reorient
nocom
symmetry c1
}

activate(mol1)

set {
  basis cc-pvdz
  scf_type df 
  e_convergence 1e-12
  d_convergence 1e-12 
} 

# frequency: 2.0 eV
w = 0.07349864501573

# lambda: 0.05
# coupling g = 0.05 / sqrt(2*w)
g = 0.05 / np.sqrt(2.0 * w)

set hilbert {
  maxiter 500
  cavity_frequency         [0.0, 0.0, $w]
  cavity_coupling_strength [0.0, 0.0, $g]

  qed_cc_include_u0 true
  qed_cc_include_u1 true
  qed_cc_include_u2 true

  r_convergence 1e-12
}

set reference uhf
en = energy('qed-ccsd') 

ref = -76.234654403463
compare_values(ref, en, 8, "UCCSD total energy (xyz)") # TEST


activate(mol2)
set basis cc-pvdz
set hilbert {
    cavity_frequency         [$w, $w, $w]
    cavity_coupling_strength [0.0, $g, 0.0]
}
en = energy('qed-ccsd') 
compare_values(ref, en, 8, "UCCSD total energy (zxy)") # TEST

activate(mol2)
set basis cc-pvdz
set hilbert {
    cavity_frequency         [$w, $w, $w]
    cavity_coupling_strength [0.0, $g, 0.0]
}
en = energy('qed-ccsd') 
compare_values(ref, en, 8, "UCCSD total energy (yzx)") # TEST
