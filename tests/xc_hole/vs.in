#! visualize exchange-correlation hole in N2(6,6) / PQG

# job description:
#print('        N2 / cc-pVDZ / DQG(6,6), scf_type = DF, rNN = 1.1 A')

memory 8 gb

sys.path.insert(0, '../../..')
import hilbert

molecule n2 {
0 1
li 0.0 0.0 0.0
h 0.0 0.0 9
symmetry c1
units bohr
}

set {
  basis cc-pvdz
  scf_type disk_df
  d_convergence      1e-10
  maxiter 500
  restricted_docc [ 1 ]
  active          [ 2 ]
  #restricted_docc [ 1, 0, 0, 0]
  #active          [ 2, 0, 0, 0]
  DFT_SPHERICAL_POINTS 74
}

set hilbert {
  maxiter 20000
  orbopt_maxiter 20
  positivity dqg
  r_convergence  1e-5
  e_convergence  1e-6
  opdm_write_full true
  tpdm_write_full true
}

#set dft_spherical_points 5810
#set dft_radial_points 100

en,wfn = energy('v2rdm-casscf',return_wfn=True)

ks = hilbert.ks_inversion(ref_wfn=wfn)

x = ks.grid_x()
y = ks.grid_y()
z = ks.grid_z()
rho_a = ks.rho_a()
rho_b = ks.rho_b()

vs = ks.slater_potential()

C = ks.ks_orbitals()

