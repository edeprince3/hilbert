# PYTHONPATH must include directory above plugin directory.
#     Define either externally or here, then import plugin.
sys.path.insert(0, '../../..')
import hilbert
import numpy as np

molecule {
0 1
O    0.00000   0.00000   0.12716
H    0.75808   0.00000  -0.50864
H   -0.75808   0.00000  -0.50864
no_reorient
nocom
symmetry c1
}

set {
  basis aug-cc-pvdz
  scf_type df
  e_convergence 1e-11
  d_convergence 1e-11
  cholesky_tolerance 1e-14
  ints_tolerance 0.0
  df_fitting_condition 1e-16
  property "HYPERPOLARIZABILITY"
} 

# freq: w
w = 0.07349864501573

# lambda: 0.05
# coupling g = 0.05 / sqrt(2*w)
g = 0.05 / np.sqrt(2.0 * w)

set hilbert {
  maxiter 500
  cavity_frequency         [0.0, 0.0, $w]
  cavity_coupling_strength [0.0, 0.0, $g]
  maxdim                   15
  indim                    5
  qed_dft_functional hf
}

# unrestricted tddft
set reference uks 
energy('qed-dft')

print_variables()

print('')
print('    ==> ALPHA <==')
print('')
compare_values( 9.532777853490, psi4.variable("QED-DFT ALPHA(XX)"), 8, "ALPHA(XX)")
compare_values(-0.000000000000, psi4.variable("QED-DFT ALPHA(XY)"), 8, "ALPHA(XY)")
compare_values(-0.000000000002, psi4.variable("QED-DFT ALPHA(XZ)"), 8, "ALPHA(XZ)")
compare_values( 7.412366037850, psi4.variable("QED-DFT ALPHA(YY)"), 8, "ALPHA(YY)")
compare_values( 0.000000000000, psi4.variable("QED-DFT ALPHA(YZ)"), 8, "ALPHA(YZ)")
compare_values( 8.452179498148, psi4.variable("QED-DFT ALPHA(ZZ)"), 8, "ALPHA(ZZ)")
          
print('')
print('    ==> BETA <==')
print('')
compare_values(-0.000000000006, psi4.variable("QED-DFT BETA(XXX)"), 8, "BETA(XXX)")
compare_values(-0.000000000000, psi4.variable("QED-DFT BETA(XXY)"), 8, "BETA(XXY)")
compare_values(13.867469894813, psi4.variable("QED-DFT BETA(XXZ)"), 8, "BETA(XXZ)")
compare_values( 0.000000000085, psi4.variable("QED-DFT BETA(XYY)"), 8, "BETA(XYY)")
compare_values(-0.000000000000, psi4.variable("QED-DFT BETA(XYZ)"), 8, "BETA(XYZ)")
compare_values(-0.000000000004, psi4.variable("QED-DFT BETA(XZZ)"), 8, "BETA(XZZ)")
compare_values(-0.000000000000, psi4.variable("QED-DFT BETA(YYY)"), 8, "BETA(YYY)")
compare_values(-0.161688390970, psi4.variable("QED-DFT BETA(YYZ)"), 8, "BETA(YYZ)")
compare_values(-0.000000000000, psi4.variable("QED-DFT BETA(YZZ)"), 8, "BETA(YZZ)")
compare_values( 6.598986606289, psi4.variable("QED-DFT BETA(ZZZ)"), 8, "BETA(ZZZ)")
